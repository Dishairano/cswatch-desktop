{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "cswatch Desktop",
  "version": "0.1.0",
  "identifier": "gg.cswatch.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "cswatch Desktop",
        "width": 1080,
        "height": 720,
        "minWidth": 720,
        "minHeight": 520,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: asset: https:; connect-src 'self' https://cswatch.gg https://*.cswatch.gg ipc: http://ipc.localhost;"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "cswatch.gg",
    "copyright": "Copyright 2026 cswatch.gg",
    "category": "Utility",
    "shortDescription": "CS2 roster intel and live score, powered by cswatch.gg",
    "longDescription": "cswatch Desktop connects to Counter-Strike 2's official Game State Integration to show your match roster with cswatch.gg risk scores and live score — without touching the game process. VAC-safe.",
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Dishairano/cswatch-desktop-releases/releases/latest/download/latest.json"
      ],
      "pubkey": ""
    }
  }
}
